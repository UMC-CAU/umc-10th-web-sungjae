# [성재의 mission2 전용 최적화 .gitignore]

# 1. 의존성 (절대 올라가면 안 됨)
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# 2. 빌드 결과물
dist/
dist-ssr/
*.local

# 3. 로그 파일
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 4. macOS 전용 (맥북 실시간 생성 파일 방지)
.DS_Store
.DS_Store?
._*
.AppleDouble
.LSOverride
Icon

# 5. 에디터 설정 (VS Code 관련)
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 6. 기타 임시 파일
**/*.backup.*
**/*.back.*
tmp/